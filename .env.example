TELEGRAM_BOT_TOKEN=1234567890:telegram-bot-token
TELEGRAM_DEFAULT_CHAT_ID=123456789
# Transport: "stdio" (default — for local MCP clients like Claude Code, Cursor, Claude Desktop)
# or "http" (for cloud MCP clients or self-hosted servers).
TELEGRAM_BOT_MCP_TRANSPORT=stdio
# Only used when transport=http
TELEGRAM_BOT_MCP_PORT=3000
TELEGRAM_BOT_MCP_LOG_LEVEL=info
